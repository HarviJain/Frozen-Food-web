# ── Abhyuday Foods Backend — Environment Variables ──
# Copy this file to .env and fill in your values.
# NEVER commit the real .env to version control.

# Flask secret key — change this to a long random string in production
SECRET_KEY=abfc-change-this-to-a-long-random-string-in-production

# Database URL
# SQLite (default — good for dev / single-server hosting):
DATABASE_URL=sqlite:///database/abfc.db

# PostgreSQL (for production / cloud hosting):
# DATABASE_URL=postgresql://username:password@host:5432/abfc_db

# Flask environment
FLASK_ENV=development
# FLASK_ENV=production